{
  "name": "brindaworld",
  "version": "1.0.0",
  "description": "BrindaWorld - Educational gaming platform for girls aged 6-14",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "build": "cd client && npm install && npm run build",
    "dev": "concurrently \"node index.js\" \"cd client && npm run dev\"",
    "migrate": "node src/migrate.js",
    "install:all": "npm install && cd client && npm install",
    "test": "jest --forceExit --detectOpenHandles tests/",
    "test:coverage": "jest --coverage --forceExit tests/"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.9.8",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "supertest": "^7.2.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3"
  }
}
